<Window
    x:Class="AgentHarness.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AgentHarness.WinUI"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    >

    <Grid Background="{StaticResource Brush.Background.MicaAlt}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main Content with NavigationView -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            PaneDisplayMode="LeftCompact"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged"
            Background="{StaticResource Brush.Background.MicaAlt}">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Home}" FontFamily="{StaticResource SegoeFluentIcons}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Chat" Tag="Chat">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Chat}" FontFamily="{StaticResource SegoeFluentIcons}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Library" Tag="Library">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Library}" FontFamily="{StaticResource SegoeFluentIcons}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Skills" Tag="Skills">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Skills}" FontFamily="{StaticResource SegoeFluentIcons}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Settings}" FontFamily="{StaticResource SegoeFluentIcons}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel Padding="8">
                    <TextBlock
                        Text="Recent Sessions"
                        Style="{StaticResource TextBlock.Caption}"
                        Margin="0,0,0,8" />
                    <ListView
                        ItemsSource="{x:Bind _viewModel.FooterItems, Mode=OneWay}"
                        SelectedItem="{x:Bind _viewModel.SelectedFooterItem, Mode=TwoWay}"
                        Background="Transparent"
                        BorderThickness="0" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" Padding="24" />
        </NavigationView>

        <!-- Status Bar -->
        <Grid
            Grid.Row="1"
            Height="28"
            Background="{StaticResource Brush.Background.MicaAlt}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="Model: idle"
                Style="{StaticResource TextBlock.Caption}"
                VerticalAlignment="Center"
                Margin="12,0" />

            <TextBlock
                Grid.Column="1"
                Text="Tools: 0 loaded"
                Style="{StaticResource TextBlock.Caption}"
                VerticalAlignment="Center"
                Margin="12,0" />

            <TextBlock
                Grid.Column="2"
                Text="0 tok/s"
                Style="{StaticResource TextBlock.Caption}"
                VerticalAlignment="Center"
                Margin="12,0" />

            <TextBlock
                Grid.Column="3"
                Text="VRAM: -- MB"
                Style="{StaticResource TextBlock.Caption}"
                VerticalAlignment="Center"
                Margin="12,0" />
        </Grid>
    </Grid>
</Window>
