<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         COLOR PALETTE — Dark Theme
         ============================================ -->

    <!-- Base Colors -->
    <Color x:Key="Color.Background.Base">#FF1C1C1E</Color>
    <Color x:Key="Color.Background.MicaAlt">#FF2A2A2D</Color>
    <Color x:Key="Color.Background.Surface">#FF343438</Color>
    <Color x:Key="Color.Background.Glass">#40343438</Color>
    <Color x:Key="Color.Border.Subtle">#FF3D3D41</Color>

    <!-- Accent Colors -->
    <Color x:Key="Color.Accent.Primary">#FFD4A373</Color>
    <Color x:Key="Color.Accent.PrimaryHover">#FFE4B383</Color>
    <Color x:Key="Color.Accent.PrimaryPressed">#FFC49363</Color>
    <Color x:Key="Color.Accent.Glow">#4DD4A373</Color>

    <!-- Text Colors -->
    <Color x:Key="Color.Text.Primary">#FFFFFFFF</Color>
    <Color x:Key="Color.Text.Secondary">#FFB0B0B8</Color>
    <Color x:Key="Color.Text.Disabled">#FF6E6E76</Color>

    <!-- Semantic -->
    <Color x:Key="Color.Success">#FF4CAF50</Color>
    <Color x:Key="Color.Warning">#FFFF9800</Color>
    <Color x:Key="Color.Error">#FFE53935</Color>

    <!-- ============================================
         BRUSHES
         ============================================ -->

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="Brush.Background.MicaAlt" Color="{StaticResource Color.Background.MicaAlt}" />
    <SolidColorBrush x:Key="Brush.Background.Surface" Color="{StaticResource Color.Background.Surface}" />
    <SolidColorBrush x:Key="Brush.Background.Glass" Color="{StaticResource Color.Background.Glass}" />
    <SolidColorBrush x:Key="Brush.Background.Acrylic" Color="{StaticResource Color.Background.Glass}" Opacity="0.6" />

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Border.Subtle}" />

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="{StaticResource Color.Accent.Primary}" />
    <SolidColorBrush x:Key="Brush.Accent.PrimaryHover" Color="{StaticResource Color.Accent.PrimaryHover}" />
    <SolidColorBrush x:Key="Brush.Accent.PrimaryPressed" Color="{StaticResource Color.Accent.PrimaryPressed}" />
    <SolidColorBrush x:Key="Brush.Accent.Glow" Color="{StaticResource Color.Accent.Glow}" />

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.Disabled" Color="{StaticResource Color.Text.Disabled}" />

    <!-- Semantic Brushes -->
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Error}" />

    <!-- Shimmer Brush (animated gradient placeholder) -->
    <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#15343438" Offset="0.0" />
        <GradientStop Color="#25343438" Offset="0.5" />
        <GradientStop Color="#15343438" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ============================================
         CORNER RADII
         ============================================ -->
    <CornerRadius x:Key="ControlCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="BubbleCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>

    <!-- ============================================
         PADDING / SPACING
         ============================================ -->
    <Thickness x:Key="Padding.Page">24</Thickness>
    <Thickness x:Key="Padding.Card">12,10</Thickness>
    <Thickness x:Key="Padding.Chip">6,3</Thickness>

    <!-- ============================================
         ANIMATION DURATIONS
         ============================================ -->
    <Duration x:Key="Duration.Fast">0:0:0.150</Duration>
    <Duration x:Key="Duration.Normal">0:0:0.250</Duration>

    <!-- ============================================
         EASING FUNCTIONS
         ============================================ -->
    <CubicEase x:Key="Easing.Standard" EasingMode="EaseOut" />
    <!-- SpringEasingFunction requires WinUI 3 preview features - using CubicEase as fallback -->
    <CubicEase x:Key="Easing.Spring" EasingMode="EaseOut" />

    <!-- ============================================
         FONT FAMILIES
         ============================================ -->
    <FontFamily x:Key="Font.FluentIcons">Segoe Fluent Icons</FontFamily>
    <FontFamily x:Key="Font.Display">Segoe UI Variable Display</FontFamily>
    <FontFamily x:Key="Font.Title">Segoe UI Variable Display Semibold</FontFamily>
    <FontFamily x:Key="Font.Body">Segoe UI Variable Text</FontFamily>
    <FontFamily x:Key="Font.Caption">Segoe UI Variable Text</FontFamily>

    <!-- ============================================
         TEXTBLOCK STYLES
         ============================================ -->
    <Style x:Key="TextBlock.Caption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
    </Style>

    <Style x:Key="TextBlock.Body" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
    </Style>

    <Style x:Key="TextBlock.Title" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
    </Style>

    <!-- ============================================
         BUTTON STYLES
         ============================================ -->
    <Style x:Key="Button.Primary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Accent.Primary}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================
         TEXTBOX STYLES
         ============================================ -->
    <Style x:Key="TextBox.Primary" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- ============================================
         LISTVIEW STYLES
         ============================================ -->
    <Style x:Key="ListView.Chat" TargetType="ListView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================
         CARD STYLES
         ============================================ -->
    <Style x:Key="Card.Container" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource Padding.Card}" />
    </Style>

    <!-- ============================================
         CHIP / TAG STYLES
         ============================================ -->
    <Style x:Key="Chip.Tag" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Glass}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="{StaticResource Padding.Chip}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ============================================
         BADGE STYLES
         ============================================ -->
    <Style x:Key="Badge.Relevance" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Accent.Primary}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <!-- ============================================
         THOUGHT PANEL STYLE
         ============================================ -->
    <Style x:Key="ThoughtPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
        <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

</ResourceDictionary>
