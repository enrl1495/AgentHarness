<Page
    x:Class="AgentHarness.WinUI.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AgentHarness.WinUI">

    <Grid Padding="{StaticResource Padding.Page}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
            <TextBlock
                Text="Home"
                Style="{StaticResource TextBlock.Title}"
                HorizontalAlignment="Center" />
            <TextBlock
                Text="Welcome to AgentHarness. Select a page from the navigation menu to get started."
                Style="{StaticResource TextBlock.Body}"
                HorizontalAlignment="Center"
                Foreground="{StaticResource Brush.Text.Secondary}" />
        </StackPanel>
    </Grid>
</Page>
