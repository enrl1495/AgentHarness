<Page
    x:Class="AgentHarness.WinUI.SkillsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AgentHarness.WinUI.ViewModels"
    xmlns:converters="using:AgentHarness.WinUI.Converters"
    >

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="{StaticResource Padding.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Title -->
        <TextBlock
            Grid.Row="0"
            Text="Skills"
            Style="{StaticResource TextBlock.Title}"
            Margin="0,0,0,16" />

        <!-- Skills List -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Skills, Mode=OneWay}"
            ItemTemplate="{StaticResource SkillRowTemplate}"
            SelectionMode="None">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" Spacing="8" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.Header>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock
                        Text="{x:Bind ViewModel.Skills.Count}"
                        Style="{StaticResource TextBlock.Caption}"
                        Foreground="{StaticResource Brush.Text.Secondary}" />
                    <TextBlock
                        Text="skills loaded"
                        Style="{StaticResource TextBlock.Caption}"
                        Foreground="{StaticResource Brush.Text.Secondary}" />
                </StackPanel>
            </ListView.Header>
            <ListView.Footer>
                <Border Visibility="{x:Bind ViewModel.Skills.Count, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                    <StackPanel
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Padding="32">
                        <FontIcon
                            Glyph="&#xE7AC;"
                            FontSize="48"
                            Foreground="{StaticResource Brush.Text.Disabled}" />
                        <TextBlock
                            Text="No skills found"
                            Style="{StaticResource TextBlock.Body}"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            HorizontalAlignment="Center" />
                        <TextBlock
                            Text="Skills are loaded from %APPDATA%/AgentHarness/skills/"
                            Style="{StaticResource TextBlock.Caption}"
                            Foreground="{StaticResource Brush.Text.Disabled}"
                            HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </ListView.Footer>
        </ListView>
    </Grid>
</Page>
